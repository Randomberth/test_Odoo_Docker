# ============================================
# EJEMPLO DE CONFIGURACIÓN
# Copiar este archivo a .env y ajustar valores
# ============================================

COMPOSE_PROJECT_NAME=mi_proyecto_odoo
ODOO_VERSION=19.0
POSTGRES_VERSION=16-alpine

ODOO_CONTAINER=odoo_app
DB_CONTAINER=odoo_db

ODOO_PORT=8069

DB_HOST=postgres
DB_PORT=5432
DB_USER=odoo
DB_PASSWORD=cambia_esta_contraseña
POSTGRES_DB=postgres

# DOCUMENTACIÓN: Nombre sugerido para la base de datos
# Al abrir Odoo por primera vez, usar este valor en:
# Database Name = [valor de abajo]
DATABASE_NAME=odoo_miproyecto

ADMIN_PASSWORD=cambia_esta_clave_admin